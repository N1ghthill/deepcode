{
  "name": "@deepcode/cli",
  "version": "1.0.0",
  "description": "Terminal UI and command surface for DeepCode",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/N1ghthill/deepcode#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/N1ghthill/deepcode.git"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@deepcode/core": "workspace:*",
    "@deepcode/shared": "workspace:*",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "ink": "^4.4.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "react": "^18.3.0"
  }
}
